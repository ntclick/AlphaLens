# =============================================
# AlphaLens Agent — Environment Variables
# =============================================

# Server
PORT=3000

# Birdeye API (on-chain data)
# Get key: https://docs.birdeye.so/docs/authentication-api-keys
BIRDEYE_API_KEY=your_birdeye_key_here

# DeepSeek API (AI analysis)
# Get key: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your_deepseek_key_here

# Owner wallet private key
# Dung de mint ERC-8004 NFT (chay: npm run mint)
# Vi nay can co USDC testnet de tra gas
# Faucet: https://faucet.circle.com
# KHONG BAO GIO commit .env that len GitHub
OWNER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Optional: RPC overrides (defaults to public endpoints)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
ETH_RPC_URL=https://eth.llamarpc.com
BASE_RPC_URL=https://mainnet.base.org
ARB_RPC_URL=https://arb1.arbitrum.io/rpc
BSC_RPC_URL=https://bsc-dataseed.binance.org
POLYGON_RPC_URL=https://polygon-rpc.com
